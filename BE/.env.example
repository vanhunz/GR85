# ============================================================
# SERVER CONFIGURATION
# ============================================================

PORT=3001
NODE_ENV=development

# ============================================================
# DATABASE
# ============================================================

DATABASE_URL="mysql://root:password@localhost:3306/ecommerce"

# ============================================================
# JWT & AUTHENTICATION
# ============================================================

JWT_SECRET="your-secret-key-at-least-8-chars"

# ============================================================
# CORS & URLs
# ============================================================

CORS_ORIGIN="http://localhost:8080"
FRONTEND_URL="http://localhost:8080"
FE_DOMAIN="http://localhost:8080"

# ============================================================
# EMAIL CONFIGURATION
# ============================================================

EMAIL="your-email@gmail.com"
APP_PASSWORD="your-app-password"
OTP_EXPIRY_MINUTES=5

# ============================================================
# PAYMENT GATEWAYS
# ============================================================

# PayOS Configuration
PAYOS_CLIENT_ID="your-payos-client-id"
PAYOS_API_KEY="your-payos-api-key"
PAYOS_CHECKSUM_KEY="your-payos-checksum-key"

# VNPay Configuration
VNP_TMN_CODE="your-vnp-tmn-code"
VNP_HASH_SECRET="your-vnp-hash-secret"
VNP_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNP_RETURN_URL="http://localhost:8080/payment-result"

# ============================================================
# MOCK QR BANK (for testing)
# ============================================================

MOCK_QR_BANK_BIN="970422"
MOCK_QR_BANK_NAME="MB Bank"
MOCK_QR_ACCOUNT_NO="19031111111111"
MOCK_QR_ACCOUNT_NAME="TECHBUILTAI"
MOCK_QR_TEMPLATE="compact2"

# ============================================================
# SEPAY CONFIGURATION
# ============================================================

SEPAY_API_TOKEN="your-sepay-token"

# ============================================================
# WEBHOOK
# ============================================================

WEBHOOK_SECRET="your-webhook-secret"

# ============================================================
# AI & AUTO GENERATION (NEW)
# ============================================================

# Groq Configuration - Required for auto product generation
# Get API key from: https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxx"

# Optional: choose a Groq model
GROQ_MODEL="llama-3.1-70b-versatile"

# Pexels Configuration - Required for auto image downloading
# Get API key from: https://www.pexels.com/api/
PEXELS_API_KEY="xxxxxxxxxxxxxxxxxxxxx"
