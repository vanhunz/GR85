generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

// ================= ENUMS =================

enum UserStatus {
    ACTIVE
    BANNED
    UNVERIFIED
}

enum DiscountType {
    PERCENT
    FIXED_AMOUNT
}

enum CouponStatus {
    ACTIVE
    EXPIRED
    DISABLED
}

enum CouponScope {
    PRODUCT
    SHIPPING
}

enum ProductStatus {
    ACTIVE
    INACTIVE
}

enum SerialStatus {
    IN_STOCK
    SOLD
    DEFECTIVE
    IN_WARRANTY
}

enum PaymentMethod {
    COD
    VNPAY
    MOMO
    BANK_TRANSFER
    SEPAY
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
}

enum OrderStatus {
    PENDING
    PROCESSING
    SHIPPING
    DELIVERED
    CANCELLED
}

enum ChatRoomStatus {
    OPEN
    CLOSED
}

enum WalletTransactionType {
    TOP_UP
    PAYMENT_DEBIT
    REFUND_CREDIT
    ADJUSTMENT
}

enum ReturnRequestStatus {
    PENDING
    APPROVED
    REJECTED
    REFUNDED
    SHIPPING_BACK
    RECEIVED
    CANCELLED
}

enum NotificationType {
    WISHLIST_PRICE_DROP
    WISHLIST_NEW_COUPON
    ORDER_STATUS_CHANGED
    REVIEW_REPLY
    REVIEW_MODERATED
    SYSTEM
}

enum ReviewThreadStatus {
    OPEN
    WAITING_ADMIN
    WAITING_CUSTOMER
    RESOLVED
}

// ================= 1. NGƯỜI DÙNG & PHÂN QUYỀN =================

model User {
    id           Int        @id @default(autoincrement())
    email        String     @unique
    passwordHash String     @map("password_hash")
    fullName     String     @map("full_name")
    phone        String?
    address      String?    @db.Text
    avatarUrl    String?    @map("avatar_url")
    walletBalance Decimal    @default(0) @map("wallet_balance") @db.Decimal(15, 2)
    status       UserStatus @default(ACTIVE)
    roleId       Int?       @map("role_id")
    createdAt    DateTime   @default(now()) @map("created_at")
    updatedAt    DateTime   @updatedAt @map("updated_at")

    role          Role?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
    cart          Cart?
    orders        Order[]
    reviews       Review[]       @relation("ReviewAuthor")
    moderatedReviews Review[]    @relation("ReviewModerator")
    repliedReviews Review[]      @relation("ReviewReplier")
    resolvedReviewThreads Review[] @relation("ReviewThreadResolver")
    reviewReplies ReviewReply[]
    chatRooms     ChatRoom[]
    messages      Message[]
    messageReads  MessageRead[]
    aiSavedBuilds AiSavedBuild[]
    addresses     UserAddress[]
    walletTransactions WalletTransaction[]
    returnRequests ReturnRequest[]
    wishlistItems  WishlistItem[]
    notifications  Notification[]
    couponAccesses CouponUser[]
    resolvedChatRooms ChatRoomMeta[] @relation("ChatRoomResolver")
    aiRequestLogs  AiRequestLog[]

    @@map("Users")
}

model Role {
    id          Int      @id @default(autoincrement())
    name        String   @unique
    description String?  @db.Text
    createdAt   DateTime @default(now()) @map("created_at")

    users       User[]
    permissions RolePermission[]

    @@map("Roles")
}

model Permission {
    id          Int      @id @default(autoincrement())
    actionName  String   @unique @map("action_name")
    description String?  @db.Text
    createdAt   DateTime @default(now()) @map("created_at")

    roles RolePermission[]

    @@map("Permissions")
}

model RolePermission {
    roleId       Int @map("role_id")
    permissionId Int @map("permission_id")

    role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
    permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

    @@id([roleId, permissionId])
    @@map("Role_Permissions")
}

// ================= 2. THUỘC TÍNH SẢN PHẨM & ĐỐI TÁC =================

model Category {
    id          Int     @id @default(autoincrement())
    name        String
    slug        String  @unique
    description String? @db.Text
    isActive    Boolean @default(true) @map("is_active")
    isDeleted   Boolean @default(false) @map("is_deleted")
    updatedAt   DateTime @updatedAt @map("updated_at")

    products Product[]

    @@map("Categories")
}

model Supplier {
    id            Int     @id @default(autoincrement())
    name          String
    contactPerson String? @map("contact_person")
    phone         String?
    email         String?
    address       String? @db.Text

    products Product[]
    batches  Batch[]

    @@map("Suppliers")
}

model Coupon {
    id            Int          @id @default(autoincrement())
    code          String       @unique
    couponScope   CouponScope  @default(PRODUCT) @map("coupon_scope")
    discountType  DiscountType @map("discount_type")
    discountValue Decimal      @map("discount_value") @db.Decimal(15, 2)
    minOrderValue Decimal      @default(0) @map("min_order_value") @db.Decimal(15, 2)
    startDate     DateTime     @map("start_date")
    endDate       DateTime     @map("end_date")
    usageLimit    Int          @default(100) @map("usage_limit")
    usedCount     Int          @default(0) @map("used_count")
    status        CouponStatus @default(ACTIVE)
    createdAt     DateTime     @default(now()) @map("created_at")

    orders         Order[]      @relation("ProductCouponOrders")
    shippingOrders Order[]      @relation("ShippingCouponOrders")
    couponUsers    CouponUser[]

    @@map("Coupons")
}

model CouponUser {
    couponId  Int      @map("coupon_id")
    userId    Int      @map("user_id")
    createdAt DateTime @default(now()) @map("created_at")

    coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([couponId, userId])
    @@index([userId])
    @@map("Coupon_Users")
}

// ================= 3. SẢN PHẨM =================

model Product {
    id             Int           @id @default(autoincrement())
    categoryId     Int           @map("category_id")
    supplierId     Int?          @map("supplier_id")
    name           String
    slug           String        @unique
    price          Decimal       @db.Decimal(15, 2)
    salePrice      Decimal?      @map("sale_price") @db.Decimal(15, 2)
    saleStartAt    DateTime?     @map("sale_start_at")
    saleEndAt      DateTime?     @map("sale_end_at")
    warrantyMonths Int           @default(12) @map("warranty_months")
    stockQuantity  Int           @default(0) @map("stock_quantity") // <-- Sẽ trừ thẳng vào đây khi có đơn hàng
    lowStockThreshold Int        @default(5) @map("low_stock_threshold")
    isHomepageFeatured Boolean   @default(false) @map("is_homepage_featured")
    displayOrder   Int           @default(9999) @map("display_order")
    specifications Json
    status         ProductStatus @default(ACTIVE)
    createdAt      DateTime      @default(now()) @map("created_at")
    updatedAt      DateTime      @updatedAt @map("updated_at")

    category      Category       @relation(fields: [categoryId], references: [id])
    supplier      Supplier?      @relation(fields: [supplierId], references: [id])
    detail        ProductDetail?
    images        ProductImage[]
    batches       Batch[]
    serialNumbers SerialNumber[]
    cartItems     CartItem[]
    orderItems    OrderItem[]
    reviews       Review[]
    aiBuildItems  AiBuildItem[]
    wishlistItems WishlistItem[]
    returnItems   ReturnItem[]   @relation("ReturnItems")

    @@map("Products")
}

model ProductDetail {
    id              Int      @id @default(autoincrement())
    productId       Int      @unique @map("product_id")
    fullDescription String?  @map("full_description") @db.LongText
    inTheBox        String?  @map("in_the_box") @db.Text
    manualUrl       String?  @map("manual_url")
    warrantyPolicy  String?  @map("warranty_policy") @db.Text
    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Product_Details")
}

model ProductImage {
    id        Int      @id @default(autoincrement())
    productId Int      @map("product_id")
    imageUrl  String   @map("image_url")
    isPrimary Boolean  @default(false) @map("is_primary")
    sortOrder Int      @default(0) @map("sort_order")
    altText   String?  @map("alt_text")
    createdAt DateTime @default(now()) @map("created_at")

    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Product_Images")
}

// ================= 4. QUẢN LÝ KHO CƠ BẢN =================

model Warehouse {
    id          Int      @id @default(autoincrement())
    name        String
    address     String?  @db.Text
    managerName String?  @map("manager_name")
    createdAt   DateTime @default(now()) @map("created_at")

    batches Batch[]

    @@map("Warehouses")
}

model Batch {
    id          Int      @id @default(autoincrement())
    batchCode   String   @unique @map("batch_code")
    productId   Int      @map("product_id")
    warehouseId Int      @map("warehouse_id")
    supplierId  Int      @map("supplier_id")
    importPrice Decimal  @map("import_price") @db.Decimal(15, 2)
    quantity    Int
    createdAt   DateTime @default(now()) @map("created_at")

    product       Product        @relation(fields: [productId], references: [id])
    warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
    supplier      Supplier       @relation(fields: [supplierId], references: [id])
    serialNumbers SerialNumber[]

    @@map("Batches")
}

model SerialNumber {
    id          Int          @id @default(autoincrement())
    serialCode  String       @unique @map("serial_code")
    productId   Int          @map("product_id")
    batchId     Int          @map("batch_id")
    status      SerialStatus @default(IN_STOCK)
    orderItemId Int?         @map("order_item_id")
    createdAt   DateTime     @default(now()) @map("created_at")
    updatedAt   DateTime     @updatedAt @map("updated_at")

    product   Product    @relation(fields: [productId], references: [id])
    batch     Batch      @relation(fields: [batchId], references: [id])
    orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

    @@map("Serial_Numbers")
}

// ================= 5. MUA SẮM VÀ ĐƠN HÀNG =================

model Cart {
    id        Int      @id @default(autoincrement())
    userId    Int      @unique @map("user_id")
    createdAt DateTime @default(now()) @map("created_at")

    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    cartItems CartItem[]

    @@map("Carts")
}

model CartItem {
    id        Int @id @default(autoincrement())
    cartId    Int @map("cart_id")
    productId Int @map("product_id")
    quantity  Int @default(1)

    cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
    product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("Cart_Items")
}

model Order {
    id              Int           @id @default(autoincrement())
    userId          Int           @map("user_id")
    couponId        Int?          @map("coupon_id")
    shippingCouponId Int?         @map("shipping_coupon_id")
    totalAmount     Decimal       @map("total_amount") @db.Decimal(15, 2)
    discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(15, 2)
    shippingFee     Decimal       @default(0) @map("shipping_fee") @db.Decimal(15, 2)
    shippingDiscountAmount Decimal @default(0) @map("shipping_discount_amount") @db.Decimal(15, 2)
    shippingAddress String        @map("shipping_address") @db.Text
    phoneNumber     String        @map("phone_number")
    paymentMethod   PaymentMethod @map("payment_method")
    paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
    orderStatus     OrderStatus   @default(PENDING) @map("order_status")
    createdAt       DateTime      @default(now()) @map("created_at")
    updatedAt       DateTime      @updatedAt @map("updated_at")

    user       User        @relation(fields: [userId], references: [id])
    coupon     Coupon?     @relation("ProductCouponOrders", fields: [couponId], references: [id])
    shippingCoupon Coupon? @relation("ShippingCouponOrders", fields: [shippingCouponId], references: [id])
    orderItems OrderItem[]
    statusHistories OrderStatusHistory[]
    walletTransactions WalletTransaction[]
    returnRequests ReturnRequest[]

    @@map("Orders")
}

model OrderStatusHistory {
    id         Int         @id @default(autoincrement())
    orderId    Int         @map("order_id")
    fromStatus OrderStatus @map("from_status")
    toStatus   OrderStatus @map("to_status")
    changedBy  Int         @map("changed_by")
    note       String?     @db.Text
    createdAt  DateTime    @default(now()) @map("created_at")

    order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

    @@map("Order_Status_History")
}

model OrderItem {
    id          Int     @id @default(autoincrement())
    orderId     Int     @map("order_id")
    productId   Int     @map("product_id")
    quantity    Int
    priceAtTime Decimal @map("price_at_time") @db.Decimal(15, 2)

    order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
    product       Product        @relation(fields: [productId], references: [id])
    serialNumbers SerialNumber[]
    reviews       Review[]

    @@map("Order_Items")
}

// ================= 6. TƯƠNG TÁC VÀ CHĂM SÓC KHÁCH HÀNG =================

model Review {
    id             Int      @id @default(autoincrement())
    userId         Int      @map("user_id")
    productId      Int      @map("product_id")
    orderItemId    Int?     @map("order_item_id")
    rating         Int
    comment        String?  @db.Text
    isHidden       Boolean  @default(false) @map("is_hidden")
    hiddenReason   String?  @map("hidden_reason") @db.Text
    moderatedBy    Int?     @map("moderated_by")
    moderatedAt    DateTime? @map("moderated_at")
    adminReply     String?  @map("admin_reply") @db.Text
    adminRepliedBy Int?     @map("admin_replied_by")
    adminRepliedAt DateTime? @map("admin_replied_at")
    threadStatus   ReviewThreadStatus @default(OPEN) @map("thread_status")
    threadResolvedBy Int?    @map("thread_resolved_by")
    threadResolvedAt DateTime? @map("thread_resolved_at")
    createdAt      DateTime @default(now()) @map("created_at")
    updatedAt      DateTime @updatedAt @map("updated_at")

    user      User    @relation("ReviewAuthor", fields: [userId], references: [id], onDelete: Cascade)
    product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
    orderItem OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
    moderator User?   @relation("ReviewModerator", fields: [moderatedBy], references: [id], onDelete: SetNull)
    replier   User?   @relation("ReviewReplier", fields: [adminRepliedBy], references: [id], onDelete: SetNull)
    resolver  User?   @relation("ReviewThreadResolver", fields: [threadResolvedBy], references: [id], onDelete: SetNull)
    replies   ReviewReply[]
    images    ReviewImage[]

    @@index([isHidden, createdAt])
    @@index([moderatedBy])
    @@index([adminRepliedBy])
    @@index([threadStatus, updatedAt])
    @@index([threadResolvedBy])
    @@unique([orderItemId])
    @@index([orderItemId])

    @@map("Reviews")
}

model ReviewImage {
    id        Int      @id @default(autoincrement())
    reviewId  Int      @map("review_id")
    imageUrl  String   @map("image_url")
    isApproved Boolean @default(false) @map("is_approved")
    moderatedBy Int?   @map("moderated_by")
    moderatedAt DateTime? @map("moderated_at")
    rejectionReason String? @map("rejection_reason")
    sortOrder  Int     @default(0) @map("sort_order")
    createdAt DateTime @default(now()) @map("created_at")

    review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

    @@index([reviewId, sortOrder])
    @@map("Review_Images")
}

model ReviewReply {
    id        Int      @id @default(autoincrement())
    reviewId  Int      @map("review_id")
    senderId  Int      @map("sender_id")
    message   String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
    sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@index([reviewId, createdAt])
    @@index([senderId])
    @@map("Review_Replies")
}

model ChatRoom {
    id        Int            @id @default(autoincrement())
    userId    Int            @map("user_id")
    status    ChatRoomStatus @default(OPEN)
    createdAt DateTime       @default(now()) @map("created_at")
    updatedAt DateTime       @updatedAt @map("updated_at")

    user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages Message[]
    meta     ChatRoomMeta?

    @@map("Chat_Rooms")
}

model Message {
    id        Int      @id @default(autoincrement())
    roomId    Int      @map("room_id")
    senderId  Int      @map("sender_id")
    content   String   @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
    sender User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
    reads  MessageRead[]

    @@map("Messages")
}

model MessageRead {
    messageId Int      @map("message_id")
    userId    Int      @map("user_id")
    readAt    DateTime @default(now()) @map("read_at")

    message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([messageId, userId])
    @@index([userId, readAt])
    @@map("Message_Reads")
}

model ChatRoomMeta {
    id           Int       @id @default(autoincrement())
    roomId       Int       @unique @map("room_id")
    resolvedBy   Int?      @map("resolved_by")
    resolvedAt   DateTime? @map("resolved_at")
    customerVote Int?      @map("customer_vote")
    createdAt    DateTime  @default(now()) @map("created_at")
    updatedAt    DateTime  @updatedAt @map("updated_at")

    room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
    resolver User?    @relation("ChatRoomResolver", fields: [resolvedBy], references: [id], onDelete: SetNull)

    @@index([resolvedBy])
    @@map("Chat_Room_Meta")
}

model ChatModerationTerm {
    id        Int      @id @default(autoincrement())
    term      String   @unique
    isActive  Boolean  @default(true) @map("is_active")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@index([isActive])
    @@map("Chat_Moderation_Terms")
}

// ================= 7. AI TƯ VẤN CẤU HÌNH =================

model AiSavedBuild {
    id         Int      @id @default(autoincrement())
    userId     Int      @map("user_id")
    buildName  String   @map("build_name")
    totalPrice Decimal  @map("total_price") @db.Decimal(15, 2)
    promptUsed String?  @map("prompt_used") @db.Text
    createdAt  DateTime @default(now()) @map("created_at")

    user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    aiBuildItems AiBuildItem[]

    @@map("AI_Saved_Builds")
}

model AiBuildItem {
    id          Int     @id @default(autoincrement())
    buildId     Int     @map("build_id")
    productId   Int     @map("product_id")
    quantity    Int     @default(1)
    priceAtTime Decimal @map("price_at_time") @db.Decimal(15, 2)

    build   AiSavedBuild @relation(fields: [buildId], references: [id], onDelete: Cascade)
    product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@map("AI_Build_Items")
}

model AiSetting {
    id           Int      @id @default(1)
    isEnabled    Boolean  @default(true) @map("is_enabled")
    model        String   @default("gpt-4o-mini")
    temperature  Float    @default(0.7)
    maxToken     Int      @default(2000) @map("max_token")
    systemPrompt String   @db.Text @map("system_prompt")
    updatedAt    DateTime @updatedAt @map("updated_at")

    @@map("AI_Settings")
}

model AiRequestLog {
    id             Int      @id @default(autoincrement())
    userId         Int?     @map("user_id")
    endpoint       String
    prompt         String   @db.Text
    response       String   @db.Text
    modelUsed      String   @map("model_used")
    promptTokens   Int      @map("prompt_tokens")
    completionTokens Int    @map("completion_tokens")
    totalTokens    Int      @map("total_tokens")
    cost           Decimal  @db.Decimal(15, 6)
    createdAt      DateTime @default(now()) @map("created_at")

    user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([createdAt])
    @@map("AI_Request_Logs")
}

model EmailVerification {
    id         Int      @id @default(autoincrement())
    email      String
    otp        String
    purpose    String   @default("EMAIL_VERIFY")
    expiredAt  DateTime @map("expired_at")
    usedAt     DateTime? @map("used_at")
    createdAt  DateTime @default(now()) @map("created_at")

    @@map("Email_Verifications")
}

model UserAddress {
    id            Int      @id @default(autoincrement())
    userId        Int      @map("user_id")
    label         String?  @db.VarChar(100)
    receiverName  String   @map("receiver_name")
    phoneNumber   String   @map("phone_number")
    addressLine   String   @map("address_line") @db.Text
    isDefault     Boolean  @default(false) @map("is_default")
    createdAt     DateTime @default(now()) @map("created_at")
    updatedAt     DateTime @updatedAt @map("updated_at")

    user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("User_Addresses")
}

model WalletTransaction {
    id          Int                   @id @default(autoincrement())
    userId      Int                   @map("user_id")
    orderId     Int?                  @map("order_id")
    amount      Decimal               @db.Decimal(15, 2)
    type        WalletTransactionType
    note        String?               @db.Text
    createdAt   DateTime              @default(now()) @map("created_at")

    user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
    order       Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([orderId])
    @@map("Wallet_Transactions")
}

model ReturnRequest {
    id                 Int                 @id @default(autoincrement())
    orderId            Int                 @map("order_id")
    userId             Int                 @map("user_id")
    reason             String              @db.Text
    note               String?             @db.Text
    status             ReturnRequestStatus @default(PENDING)
    bankName           String?             @map("bank_name")
    bankAccountNumber  String?             @map("bank_account_number")
    bankAccountName    String?             @map("bank_account_name")
    reviewedBy         Int?                @map("reviewed_by")
    rejectReason       String?             @map("reject_reason") @db.Text
    refundAmount       Decimal?            @map("refund_amount") @db.Decimal(15, 2)
    requestedAt        DateTime            @default(now()) @map("requested_at")
    reviewedAt         DateTime?           @map("reviewed_at")
    receivedAt         DateTime?           @map("received_at")
    refundedAt         DateTime?           @map("refunded_at")

    order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
    user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
    items              ReturnItem[]
    media              ReturnMedia[]
    logs               ReturnLog[]

    @@index([orderId])
    @@index([userId])
    @@index([status])
    @@map("Return_Requests")
}

model ReturnItem {
    id         Int      @id @default(autoincrement())
    returnId   Int      @map("return_id")
    productId  Int      @map("product_id")
    quantity   Int
    createdAt  DateTime @default(now()) @map("created_at")

    returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)
    product       Product       @relation("ReturnItems", fields: [productId], references: [id], onDelete: Restrict)

    @@index([returnId])
    @@index([productId])
    @@map("Return_Items")
}

model ReturnMedia {
    id        Int      @id @default(autoincrement())
    returnId  Int      @map("return_id")
    mediaUrl  String   @map("media_url")
    sortOrder Int      @default(0) @map("sort_order")
    createdAt DateTime @default(now()) @map("created_at")

    returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

    @@index([returnId])
    @@map("Return_Media")
}

model ReturnLog {
    id        Int      @id @default(autoincrement())
    returnId  Int      @map("return_id")
    action    String
    createdBy Int?     @map("created_by")
    note      String?  @db.Text
    createdAt DateTime @default(now()) @map("created_at")

    returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

    @@index([returnId])
    @@index([createdAt])
    @@map("Return_Logs")
}

model WishlistItem {
    id         Int      @id @default(autoincrement())
    userId     Int      @map("user_id")
    productId  Int      @map("product_id")
    createdAt  DateTime @default(now()) @map("created_at")

    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

    @@unique([userId, productId])
    @@index([userId])
    @@index([productId])
    @@map("User_Wishlist")
}

model Notification {
    id         Int              @id @default(autoincrement())
    userId     Int              @map("user_id")
    type       NotificationType
    title      String
    message    String           @db.Text
    payload    Json?
    isRead     Boolean          @default(false) @map("is_read")
    createdAt  DateTime         @default(now()) @map("created_at")
    readAt     DateTime?        @map("read_at")

    user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, isRead])
    @@index([createdAt])
    @@map("Notifications")
}

// ================= 8. NGÂN HÀNG & THANH TOÁN =================

model Bank {
    id        Int      @id @default(autoincrement())
    code      String   @unique
    name      String
    isActive  Boolean  @default(true) @map("is_active")
    createdAt DateTime @default(now()) @map("created_at")

    bankAccounts BankAccount[]

    @@map("Banks")
}

model BankAccount {
    id              Int      @id @default(autoincrement())
    bankId          Int      @map("bank_id")
    accountNumber   String   @unique @map("account_number")
    accountName     String   @map("account_name")
    accountHolder   String   @map("account_holder")
    isVerified      Boolean  @default(false) @map("is_verified")
    createdAt       DateTime @default(now()) @map("created_at")
    updatedAt       DateTime @updatedAt @map("updated_at")

    bank            Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

    @@index([bankId])
    @@index([accountNumber])
    @@index([isVerified])
    @@map("Bank_Accounts")
}